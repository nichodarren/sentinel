# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/

# --- Jupyter ---
.ipynb_checkpoints/
*-checkpoint.ipynb

# --- OS / editor ---
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/

# --- Local working/scratch (not part of the deliverable) ---
# Build scratch, scratch notebooks, and any local archive live OUTSIDE this repo,
# but guard against accidental copies landing here:
_archive*/
*_backup.ipynb
scratch/
tmp/

# --- Generated / regenerated on run (not committed) ---
# eda_figs/ holds PNG fallbacks for the interactive figures. The matplotlib panels
# render inline in notebook.ipynb itself, and the notebook recreates this folder
# (os.makedirs(..., exist_ok=True)) on every execution, so it is not tracked.
eda_figs/

# Intermediate model/search caches and any persisted parquet artefacts. The notebook
# is self-contained and rebuilds everything in-process; nothing here needs committing.
artifacts/

# The internal build script and process documentation are kept out of the public repo.
build/
